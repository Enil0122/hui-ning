{"active_fact": true, "arousal": 0.8, "category": "event", "confidence": null, "content": "2026.07.11 下午她去市区面试所谓的暑假工，发现是陪酒骗局，当场识破，和朋友一起走出来。", "created_at": "2026-07-22T13:49:57.525Z", "fact_key": null, "growth_delta": "", "hit_count": 0, "id": 16, "last_hit_at": null, "response_tendency": "她在现场判断和脱身上是可靠的，不需要被当成需要保护的人。", "risk_level": "normal", "source": "", "status": "current", "tags": ["judgment", "safety"], "tension": null, "thread": "life", "title": "7.11 识破陪酒骗局", "updated_at": "2026-07-22T13:49:57.525Z", "urgency": "normal", "valence": 0.3}
